{
  "extends": [
    "config:base",
    "schedule:weekly",
    "group:allNonMajor",
    "helpers:pinGitHubActionDigests",
  ],
  "labels": ["dependencies"],
  "ignorePaths": ["**/__tests__/**"],
  "pin": false,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "depTypeList": ["peerDependencies"],
      "enabled": false,
    },
    {
      groupName: "upstream",
      matchPackageNames: ["vite"],
      matchPackagePrefixes: ["@vitejs"],
    },
    {
      groupName: "prettier",
      matchPackageNames: ["prettier"],
    },
    {
      "matchDepTypes": ["action"],
      "excludePackagePrefixes": ["actions/", "github/"],
      "pinDigests": true,
    },
  ],
  "ignoreDeps": [
    // manually bumping
    "node",

    // breaking changes
    "kill-port", // `kill-port:^2.0.0 has perf issues (#8392)
  ],
}
