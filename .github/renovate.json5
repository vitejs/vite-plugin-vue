{
  extends: [
    'config:recommended',
    'schedule:weekly',
    'group:allNonMajor',
    'helpers:pinGitHubActionDigests',
  ],
  labels: [
    'dependencies',
  ],
  ignorePaths: [
    '**/__tests__/**',
  ],
  pin: {
    enabled: false,
  },
  rangeStrategy: 'bump',
  packageRules: [
    {
      matchDepTypes: [
        'peerDependencies',
      ],
      enabled: false,
    },
    {
      groupName: 'upstream',
      matchPackageNames: [
        'vite',
        '@vitejs{/,}**',
      ],
    },
    {
      matchDepTypes: [
        'action',
      ],
      pinDigests: true,
      matchPackageNames: [
        '!actions/{/,}**',
        '!github/{/,}**',
      ],
    },
  ],
  ignoreDeps: [
    'node',
    'kill-port',
  ],
}
